	@PayloadRoot(namespace = NS, localPart = "ForgottenPasswordRequest")
	@ResponsePayload
	ForgottenPasswordResponse forgottenPasswordResponse(@RequestPayload ForgottenPasswordRequest request) {

		User user = userService.resetPassword(request.getLogin(), "+216", request.getPhoneNumber());
		String message = getMessage(user);
		smsComponent.send("+216", request.getPhoneNumber().replaceAll("\\D", ""), message, 13 + "", "PASSWORD RESET",
				false);
		ForgottenPasswordResponse resp = new ForgottenPasswordResponse();
		resp.setPasswordReset(true);
		return resp;
	}

