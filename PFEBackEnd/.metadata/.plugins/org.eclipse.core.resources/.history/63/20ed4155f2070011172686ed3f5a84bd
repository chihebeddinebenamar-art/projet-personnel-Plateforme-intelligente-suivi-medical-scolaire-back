	private String getMessage(User user) {
		StringBuilder bd = new StringBuilder(256);
		bd.append("Educanet vous informe que votre mot de passe est réinitialisé. Nouveau Mot de passe :");
		bd.append(user.getMotpass());
		bd.append(" .");
		bd.append(
				"Télécharger notre application mobile: http://onelink.to/g2zebb , ou accéder au web: mon-compte.educanet.pro.");
		return bd.toString();
	}

